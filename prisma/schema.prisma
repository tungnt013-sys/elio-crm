generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmitterType {
  PARENT
  STUDENT
}

enum ProgramType {
  UNDERGRAD
  GRAD
  PHD
}

enum Relationship {
  PARENT
  SIBLING
  GUARDIAN
  OTHER
}

enum FinancialDocsStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
}

enum UserRole {
  ADMIN
  SALES
  COUNSELOR
  PARENT
  STUDENT
  PENDING
}

enum StaffRole {
  SALES
  COUNSELOR
  ADMIN
}

enum Stage {
  S1
  S2
  S3
  S4
  S5
  S6
  S7
  S8
  S9
  S10
  S11
  S12
  S13
}

enum PicType {
  SALES
  COUNSELOR
}

enum LossReason {
  NO_NEED
  NOT_CONTACTABLE
  COST
  CHANGED_PLANS
  SCHEDULE
  CHOSE_COMPETITOR
  TOO_YOUNG
  OTHER
}

enum ActivityType {
  CALL
  TEXT
  EMAIL
  ZALO
  MEETING
  NOTE
  DOCUMENT_UPLOAD
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum TestName {
  IELTS
  SAT
  GRE
  TOEFL
  DET
  AP
  IB
  GMAT
  OTHER
}

enum Currency {
  USD
  VND
}

enum EngagementStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
}

enum TaskOwnerType {
  STUDENT
  ELIO
  PARENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum DocumentType {
  TRANSCRIPT
  ESSAY_DRAFT
  ESSAY_FINAL
  RESUME
  CERTIFICATE
  TEST_SCORE
  FINANCIAL_DOC
  RECOMMENDATION_LETTER
  OFFER_LETTER
  OTHER
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  COMPLETED
}

enum PaymentType {
  DEPOSIT
  INSTALLMENT
  FINAL
  FULL
}

enum AutomationCondition {
  STILL_IN_STAGE
  TASK_NOT_DONE
  NO_ACTIVITY
}

enum AutomationRecipientRole {
  ASSIGNED_COUNSELOR
  ASSIGNED_SALES
  ADMIN
}

enum JobStatus {
  PENDING
  SENT
  CANCELLED
  CONDITION_NOT_MET
}

model Contact {
  id                 String      @id
  createdAt          DateTime
  submitterType      SubmitterType
  fullName           String
  email              String?
  phone              String?
  address            String?
  addressLine2       String?
  city               String?
  state              String?
  zipCode            String?
  country            String?
  gradeLevel         String
  gradeLevelOther    String?
  school             String?
  schoolCity         String?
  gpaScale10         String?
  specializedSubject String?
  gpaScale4          String?
  currentMajor       String?
  hasTakenTests      String?
  plansFutureTests   String?
  plannedTests       String?
  plannedTestsOther  String?
  hasResume          String?
  resumeUrl          String?
  extracurriculars   String?
  workExperience     String?
  targetCountries    String?
  preferredUsRegions String?
  intendedMajor      String?
  whyMajor           String?
  targetSchools      String?
  expectedStart      String?
  financialSources   String?
  budget             String?
  desiredServices    String?
  leadSource         String?
  specialRequests    String?
  referralCode       String?
  testScoresRaw      String?
  programType        ProgramType
  firstContactedAt   DateTime?
  lastContactedAt    DateTime?
  salesRunningNotes  String?
  updatedAt          DateTime    @updatedAt

  parents            Parent[]
  users              User[]
  pipelineStages     PipelineStage[]
  activityLogs       ActivityLog[]
  meetingNotes       MeetingNote[]
  testScores         TestScore[]
  proposals          Proposal[]
  engagements        ProgramEngagement[]
  documents          Document[]
  contracts          Contract[]
  jobs               ScheduledEmailJob[]

  @@index([email])
  @@index([fullName])
}

model Parent {
  id                  String              @id @default(uuid())
  studentId           String
  fullName            String
  email               String?
  phone               String?
  relationship        Relationship
  financialDocsStatus FinancialDocsStatus @default(NOT_STARTED)

  student             Contact             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  users               User[]

  @@index([phone])
  @@index([email])
  @@index([fullName])
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String
  avatarUrl   String?
  role        UserRole  @default(PENDING)
  googleId    String    @unique
  staffId     String?   @unique
  contactId   String?   @unique
  parentId    String?   @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  staff       Staff?    @relation(fields: [staffId], references: [id], onDelete: SetNull)
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  parent      Parent?   @relation(fields: [parentId], references: [id], onDelete: SetNull)

  changedStages    PipelineStage[]       @relation("ChangedBy")
  createdProposals Proposal[]
  uploadedDocs     Document[]
  createdRules     EmailAutomationRule[]
  updatedPrices    PricingConfig[]
}

model Staff {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  role       StaffRole
  active     Boolean     @default(true)

  user       User?
  stages     PipelineStage[]
  activity   ActivityLog[]
  meetings   MeetingNote[]
  engagements ProgramEngagement[]
  tasks      Task[]
}

model PipelineStage {
  id               String      @id @default(uuid())
  studentId        String
  stage            Stage
  picType          PicType
  assignedToId     String
  enteredAt        DateTime    @default(now())
  exitedAt         DateTime?
  changedById      String?
  lossReason       LossReason?
  lossReasonDetail String?
  notes            String?

  student          Contact     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignedTo       Staff       @relation(fields: [assignedToId], references: [id])
  changedBy        User?       @relation("ChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([studentId, enteredAt])
  @@index([stage, exitedAt])
}

model ActivityLog {
  id            String       @id @default(uuid())
  studentId     String
  staffId       String
  type          ActivityType
  direction     Direction
  content       String
  createdAt     DateTime     @default(now())
  pipelineStage Stage

  student       Contact      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  staff         Staff        @relation(fields: [staffId], references: [id])

  @@index([studentId, createdAt])
}

model MeetingNote {
  id            String              @id @default(uuid())
  studentId     String
  counselorId   String
  engagementId  String?
  pipelineStage Stage?
  meetingDate   DateTime
  title         String
  content       String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  student       Contact             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor     Staff               @relation(fields: [counselorId], references: [id])
  engagement    ProgramEngagement?  @relation(fields: [engagementId], references: [id], onDelete: SetNull)

  @@index([studentId, meetingDate])
}

model TestScore {
  id             String      @id @default(uuid())
  studentId      String
  testName       TestName
  testNameOther  String?
  score          String
  scoreBreakdown Json?
  testDate       DateTime?
  isPlanned      Boolean
  notes          String?
  createdAt      DateTime    @default(now())

  student        Contact     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Proposal {
  id            String              @id @default(uuid())
  studentId     String
  engagementId  String?
  proposalUrl   String
  quoteAmount   Float?
  quoteCurrency Currency            @default(USD)
  isCustomQuote Boolean             @default(false)
  quoteNotes    String?
  sentAt        DateTime?
  createdById   String
  createdAt     DateTime            @default(now())

  student       Contact             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  engagement    ProgramEngagement?  @relation(fields: [engagementId], references: [id], onDelete: SetNull)
  createdBy     User                @relation(fields: [createdById], references: [id])

  @@index([studentId, createdAt])
}

model ProgramEngagement {
  id           String           @id @default(uuid())
  studentId    String
  counselorId  String
  programType  ProgramType
  targetIntake String
  startDate    DateTime
  endDate      DateTime
  status       EngagementStatus

  student      Contact          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor    Staff            @relation(fields: [counselorId], references: [id])
  meetingNotes MeetingNote[]
  proposals    Proposal[]
  milestones   Milestone[]

  @@index([studentId, status])
}

model Milestone {
  id          String          @id @default(uuid())
  engagementId String
  monthLabel  String
  order       Int
  status      MilestoneStatus @default(UPCOMING)
  startedAt   DateTime?
  completedAt DateTime?

  engagement  ProgramEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([engagementId, order])
}

model Task {
  id           String       @id @default(uuid())
  milestoneId  String
  title        String
  description  String?
  ownerType    TaskOwnerType
  assignedToId String?
  status       TaskStatus   @default(TODO)
  dueDate      DateTime?
  completedAt  DateTime?

  milestone    Milestone    @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  assignedTo   Staff?       @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
}

model Document {
  id          String       @id @default(uuid())
  studentId   String
  type        DocumentType
  version     Int
  fileUrl     String
  uploadedById String
  uploadedAt  DateTime     @default(now())
  notes       String?

  student     Contact      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploadedBy  User         @relation(fields: [uploadedById], references: [id])

  @@index([studentId, type])
}

model Contract {
  id              String         @id @default(uuid())
  studentId       String
  contractCode    String
  contractSent    Boolean        @default(false)
  status          ContractStatus @default(DRAFT)
  shippingAddress String?
  recipientName   String?
  recipientPhone  String?
  contractResent  Boolean        @default(false)
  shippingCost    Float?
  invoiceUrl      String?
  notes           String?
  createdAt       DateTime       @default(now())

  student         Contact        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@index([studentId, status])
}

model Payment {
  id          String      @id @default(uuid())
  contractId  String
  amount      Float
  currency    Currency
  paymentDate DateTime
  paymentType PaymentType
  notes       String?
  createdAt   DateTime    @default(now())

  contract    Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, paymentDate])
}

model EmailAutomationRule {
  id             String                  @id @default(uuid())
  name           String
  triggerStage   Stage
  delayHours     Int
  condition      AutomationCondition
  recipientRole  AutomationRecipientRole
  ccEmails       String[]
  emailSubject   String
  emailBody      String
  isActive       Boolean                 @default(true)
  createdById    String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  createdBy      User                    @relation(fields: [createdById], references: [id])
  jobs           ScheduledEmailJob[]
}

model ScheduledEmailJob {
  id              String               @id @default(uuid())
  ruleId          String
  studentId       String
  scheduledFor    DateTime
  status          JobStatus            @default(PENDING)
  sentAt          DateTime?
  cancelledReason String?

  rule            EmailAutomationRule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  student         Contact              @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
}

model PricingConfig {
  id          String      @id @default(uuid())
  gradeLevel  String
  programType ProgramType @default(UNDERGRAD)
  price       Float
  isActive    Boolean     @default(true)
  updatedById String
  updatedAt   DateTime    @updatedAt

  updatedBy   User        @relation(fields: [updatedById], references: [id])

  @@unique([gradeLevel, programType])
}
